// Data model for WortHogg. Mirrors docs/data-model.md - keep
// both in sync. Loaded from scraper output (data/parsed) via a one-time/
// periodic import script (app/prisma/import.ts), never fetched live from
// Wayback at request time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brewer {
  id               String   @id @default(cuid())
  originalUsername String   @unique
  profileUrl       String?
  sourceTimestamp  String?
  createdAt        DateTime @default(now())

  recipes          Recipe[]
  takedownRequests TakedownRequest[]

  @@index([originalUsername])
}

model Recipe {
  id                String   @id @default(cuid())
  slug              String   @unique

  title             String?
  styleName         String?

  // BrewToad's own computed "Anticipated" stats, as displayed on the
  // archived page - not recomputed from ingredients at parse time (that
  // recomputation happens separately as a QA cross-check, see
  // scraper/validate_calculator.py and lib/calculator).
  og                Float?
  fg                Float?
  ibu               Float?
  srm               Float?
  abv               Float?
  ibuFormula        String?

  batchSizeDisplay   String?
  boilTimeDisplay    String?
  efficiencyDisplay  String?
  notesText          String?

  brewerId          String?
  brewer            Brewer?  @relation(fields: [brewerId], references: [id])

  // Wayback provenance - displayed publicly ("Archived from brewtoad.com on
  // [date] via Wayback Machine") and doubles as the citation a takedown
  // claimant points at.
  sourceUrl         String
  sourceTimestamp   String
  sourceDigest      String?
  parseSource       String   // "html" | "xml" | "html+xml_crossvalidated"
  parseConfidence   Float

  // Set by an approved takedown request; suppresses public visibility
  // without hard-deleting the row (audit trail preserved).
  isHidden          Boolean  @default(false)
  takedownStatus    String?  // null | "pending" | "approved" | "rejected"

  // BrewToad's "make a clone" feature spawned independent recipes that are
  // byte-identical copies. prisma/dedupe.ts consolidates each set of clones
  // into one canonical row; cloneCount records how many identical copies were
  // folded in (0 = never had duplicates).
  cloneCount        Int      @default(0)

  scrapedAt         DateTime @default(now())

  fermentables      RecipeFermentable[]
  hops              RecipeHop[]
  yeasts            RecipeYeast[]
  miscs             RecipeMisc[]
  comments          RecipeComment[]
  takedownRequests  TakedownRequest[]
  pitchingProtocol  RecipePitchingProtocol?

  @@index([styleName])
  @@index([abv])
  @@index([ibu])
  @@index([brewerId])
  @@index([isHidden, scrapedAt])
}

model RecipeFermentable {
  id            String  @id @default(cuid())
  recipeId      String
  recipe        Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name          String
  amountDisplay String?
  amountLb      Float?  // normalized to lb regardless of source display unit
  percent       String?
  maltster      String?
  use           String?
  ppg           Float?
  colorLovibond Float?
  refUrl        String? // links to FermentableRef.externalId when resolvable
  sortOrder     Int     @default(0)

  @@index([recipeId])
}

model RecipeHop {
  id            String  @id @default(cuid())
  recipeId      String
  recipe        Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name          String
  amountDisplay String?
  amountOz      Float?  // normalized to oz regardless of source display unit
  timeDisplay   String?
  timeMinutes   Float?
  use           String?
  form          String?
  alphaAcidPct  Float?
  refUrl        String?
  sortOrder     Int     @default(0)

  @@index([recipeId])
}

model RecipeYeast {
  id             String  @id @default(cuid())
  recipeId       String
  recipe         Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name           String
  labProduct     String?
  attenuationPct Float?
  refUrl         String?

  @@index([recipeId])
}

// A recipe's chosen yeast pitching + propagation protocol, made a permanent
// part of the recipe. One-to-one with Recipe. Stores the raw calculator
// inputs (see lib/pitching/formulas.ts) so the embedded calculator on the
// recipe page can reproduce the exact plan; results are recomputed, never
// stored. Populated via the admin-gated save action, not the Wayback import.
model RecipePitchingProtocol {
  id               String   @id @default(cuid())
  recipeId         String   @unique
  recipe           Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  // Batch target
  volume           Float
  volumeUnit       String   // "gal" | "L"
  og               Float
  pitchType        String   // "ale" | "hybrid" | "lager"

  // Yeast source
  source           String   // "liquid" | "dry" | "slurry"
  packs            Float?
  grams            Float?
  slurryMl         Float?
  yeastFractionPct Float?
  ageDays          Float?
  decayModel       String   // classic | optimistic | whiteLabs | wyeast

  // Starter / propagation
  starterType      String   // none | simple | simpleO2 | shaking | aeration | stirPlate
  starterMl        Float?

  notes            String?
  updatedAt        DateTime @updatedAt
  updatedBy        String?
}

model RecipeMisc {
  id       String  @id @default(cuid())
  recipeId String
  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  name     String
  amount   String?
  use      String?
  time     String?

  @@index([recipeId])
}

model RecipeComment {
  id                  String  @id @default(cuid())
  recipeId            String
  recipe              Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  originalCommentId   String? // BrewToad's own comment id, e.g. "18811"
  commenter           String?
  commenterProfileUrl String?
  timestampDisplay    String?
  text                String
  parentCommentId     String? // preserves thread structure (flattened list)

  @@index([recipeId])
}

// Ingredient reference database scraped from /generic-fermentables,
// /hops, /yeasts - powers the calculator's ingredient picker (M6) and
// backfills missing per-recipe properties.
model FermentableRef {
  id            String  @id @default(cuid())
  externalId    String  @unique // numeric id from /generic-fermentables/<id>
  name          String
  ppg           Float?
  colorLovibond Float?
  type          String?
  origin        String?
}

model HopRef {
  id           String  @id @default(cuid())
  externalId   String  @unique // numeric id from /hops/<id>
  name         String
  alphaAcidPct Float?
}

model YeastRef {
  id             String  @id @default(cuid())
  externalId     String  @unique // numeric id from /yeasts/<id>
  name           String
  lab            String?
  attenuationPct Float?
}

model TakedownRequest {
  id             String    @id @default(cuid())
  recipeId       String?
  recipe         Recipe?   @relation(fields: [recipeId], references: [id])
  brewerId       String?
  brewer         Brewer?   @relation(fields: [brewerId], references: [id])

  requesterName  String
  requesterEmail String
  requestReason  String
  status         String    @default("pending") // pending | approved | rejected | completed
  submittedAt    DateTime  @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?
  notes          String?

  @@index([status])
}

// --- Competition style guidelines archive (BJCP / BA(WBC+GABF) / AWS) ---

model GuidelineEdition {
  id          String              @id // e.g. "bjcp-2021", "ba-2019", "aws-2025"
  system      String // BJCP | BA | AWS
  year        Int
  title       String
  sourceUrl   String
  attribution String
  categories  GuidelineCategory[]

  @@unique([system, year])
}

model GuidelineCategory {
  id        String           @id
  editionId String
  edition   GuidelineEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  code      String?
  name      String
  sortOrder Int
  styles    GuidelineStyle[]

  @@index([editionId])
}

model GuidelineStyle {
  id          String            @id
  categoryId  String
  category    GuidelineCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  code        String?
  name        String
  sortOrder   Int
  ogMin       Float?
  ogMax       Float?
  fgMin       Float?
  fgMax       Float?
  ibuMin      Float?
  ibuMax      Float?
  srmMin      Float?
  srmMax      Float?
  abvMin      Float?
  abvMax      Float?
  impression  String?
  aroma       String?
  appearance  String?
  flavor      String?
  mouthfeel   String?
  comments    String?
  history     String?
  ingredients String?
  comparison  String?
  examples    String?
  tags        String?

  @@index([categoryId])
  @@index([name])
}

// --- Yeast / culture database (beer, wine, mead, cider, spirits, wild) ---
// A curated, sourced catalog of alcohol-producing microbes and their brewing
// specs. Populated from data/yeasts/*.json via load-yeasts.mjs (prod, Neon
// HTTPS) / prisma/import-yeasts.ts (local), NOT from the Wayback import. Every
// strain records a sourceUrl; specs are transcribed from makers' spec sheets,
// never invented. Distinct from the thin per-recipe RecipeYeast rows.

model YeastLab {
  id          String        @id // e.g. "lallemand", "white-labs", "angel-yeast"
  name        String
  country     String?
  region      String?
  url         String?
  description String?
  sortOrder   Int           @default(0)
  strains     YeastStrain[]

  @@index([country])
}

model YeastStrain {
  id          String   @id // e.g. "fermentis-us-05", "wyeast-1084"
  labId       String
  lab         YeastLab @relation(fields: [labId], references: [id], onDelete: Cascade)

  productCode String? // "US-05", "WLP001", "1056"
  name        String
  aliases     String[] @default([])

  form        String // dry | liquid | slurry | culture
  species     String // scientific, e.g. "Saccharomyces cerevisiae", "Brettanomyces bruxellensis"

  // What you can make with it, and which styles the maker recommends.
  uses             String[] @default([]) // beer | wine | mead | cider | rum | whiskey | moonshine | neutral | sake | wild
  recommendedStyles String[] @default([]) // maker's listed styles, normalized names
  styleTags        String[] @default([]) // coarse tags: stout, ipa, saison, hazy, kveik...

  // Brewing-calculator specs (nullable - sparse sources null-fill).
  attenuationMin      Float?
  attenuationMax      Float?
  tempMinF            Float?
  tempMaxF            Float?
  tempMinC            Float?
  tempMaxC            Float?
  flocculation        String? // low | medium | medium-high | high | very high
  alcoholToleranceMin Float?
  alcoholToleranceMax Float?

  // Pitching-calculator inputs.
  cellsPerUnit Float? // billion viable cells per unit
  unitLabel    String? // pack | vial | g
  optimalPitchNote String?

  isBlend         Boolean  @default(false)
  blendComponents String[] @default([])

  description String?
  flavorNotes String?
  sourceUrl   String
  attribution String?
  sortOrder   Int      @default(0)

  @@index([labId])
  @@index([name])
  @@index([species])
}
